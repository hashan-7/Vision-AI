# Database Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/h7_vision_ai?createDatabaseIfNotExist=true
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

# Google OAuth2 Credentials
spring.security.oauth2.client.registration.google.client-id=YOUR_GOOGLE_CLIENT_ID
spring.security.oauth2.client.registration.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET

# AI Engine Settings
h7.ai.engine.url=https://hashan-7-vision-a-engine.hf.space/generate
h7.ai.engine.key=YOUR_AI_ENGINE_KEY
app.image.upload-dir=uploads